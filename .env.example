# ─── Model Settings ────────────────────────────────────────────────────────────
# Open-weights model served via vLLM (Apache 2.0 / MIT, ≤16B)
# Options: Qwen/Qwen2-7B-Instruct | meta-llama/Meta-Llama-3.1-8B-Instruct | mistralai/Mixtral-8x7B-Instruct-v0.1
MODEL_NAME=Qwen/Qwen2-7B-Instruct

# ─── vLLM Server ───────────────────────────────────────────────────────────────
# URL of the OpenAI-compatible vLLM server
VLLM_BASE_URL=http://vllm:8000/v1

# ─── Scoring Settings ──────────────────────────────────────────────────────────
# Number of facets per LLM call (25 is optimal; increase to 50 to speed up, decrease for reliability)
MAX_BATCH_SIZE=25

# LLM generation settings
TEMPERATURE=0.1
MAX_NEW_TOKENS=2048

# ─── Mock Mode (no GPU / local dev) ───────────────────────────────────────────
# Set to true to run the full pipeline with random mock scores (no model download needed)
USE_MOCK=false

# ─── Service URLs (used by the UI container) ──────────────────────────────────
BACKEND_URL=http://backend:8000
